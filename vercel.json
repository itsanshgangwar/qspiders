{
  "version": 2,
  "builds": [
    {
      "src": "backend/index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/backend/index.js"
    }
  ],
  "functions": {
    "backend/index.js": {
      "runtime": "nodejs18.x",
      "maxDuration": 30
    }
  }
}